import express from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
import Database from 'better-sqlite3';
import Stripe from 'stripe';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

dotenv.config();

const __filename = fileURLToPath(import.meta.url);
const __dirname = dirname(__filename);
const app = express();
const db = new Database(process.env.DATABASE_PATH);
const stripe = new Stripe(process.env.STRIPE_SECRET_KEY);

// Middleware
app.use(cors());
app.use(express.json());

// Initialize database
const createTables = () => {
  db.exec(`
    CREATE TABLE IF NOT EXISTS resumes (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL,
      email TEXT NOT NULL,
      phone TEXT,
      summary TEXT,
      experience TEXT,
      education TEXT,
      skills TEXT,
      userId TEXT UNIQUE NOT NULL,
      isSubscribed BOOLEAN DEFAULT 0,
      createdAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    );
    
    CREATE TABLE IF NOT EXISTS users (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      email TEXT UNIQUE NOT NULL,
      stripeCustomerId TEXT,
      isSubscribed BOOLEAN DEFAULT 0,
      createdAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    );
  `);
};

createTables();

// Routes
app.post('/api/resume/save', (req, res) => {
  try {
    const { userId, name, email, phone, summary, experience, education, skills } = req.body;
    
    const insert = db.prepare(`
      INSERT OR REPLACE INTO resumes 
      (userId, name, email, phone, summary, experience, education, skills)
      VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    `);
    
    insert.run(userId, name, email, phone, summary, experience, education, skills);
    res.json({ success: true, message: 'Resume saved' });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.get('/api/resume/:userId', (req, res) => {
  try {
    const { userId } = req.params;
    const resume = db.prepare('SELECT * FROM resumes WHERE userId = ?').get(userId);
    
    if (!resume) {
      return res.status(404).json({ error: 'Resume not found' });
    }
    
    res.json(resume);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.post('/api/subscribe', async (req, res) => {
  try {
    const { userId, email } = req.body;
    
    const customer = await stripe.customers.create({ email });
    const session = await stripe.checkout.sessions.create({
      customer: customer.id,
      payment_method_types: ['card'],
      line_items: [{
        price_data: {
          currency: 'usd',
          product_data: { name: 'Resume Builder Pro' },
          unit_amount: 600 // $6.00
        },
        quantity: 1
      }],
      mode: 'subscription',
      success_url: `${process.env.FRONTEND_URL}/success?session_id={CHECKOUT_SESSION_ID}`,
      cancel_url: `${process.env.FRONTEND_URL}/cancel`
    });
    
    db.prepare('INSERT OR REPLACE INTO users (email, stripeCustomerId) VALUES (?, ?)').run(email, customer.id);
    
    res.json({ sessionId: session.id });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

app.get('/api/user/:email/subscription', (req, res) => {
  try {
    const { email } = req.params;
    const user = db.prepare('SELECT * FROM users WHERE email = ?').get(email);
    
    res.json({ isSubscribed: user?.isSubscribed || false });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Health check
app.get('/api/health', (req, res) => {
  res.json({ status: 'ok' });
});

const PORT = process.env.PORT || 3001;
app.listen(PORT, () => {
  console.log(`Resume Builder API running on port ${PORT}`);
});